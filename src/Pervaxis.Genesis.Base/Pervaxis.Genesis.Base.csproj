<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <!-- Microsoft Extensions for DI, Logging, Options -->
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="9.0.0" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="9.0.0" />
    <PackageReference Include="Microsoft.Extensions.Options" Version="9.0.0" />

    <!-- YAML parsing -->
    <PackageReference Include="YamlDotNet" Version="16.2.1" />
  </ItemGroup>

  <ItemGroup>
    <!-- Core platform abstractions (provides GenesisOptionsBase, ProviderResult<T>, ICache, IFileStorage, ITenantContext, etc.) -->
    <PackageReference Include="Pervaxis.Core.Abstractions" Version="1.1.0" />

    <!-- Observability: Serilog structured logging + OpenTelemetry tracing -->
    <ProjectReference Include="..\..\..\Core\src\Pervaxis.Core.Observability\Pervaxis.Core.Observability.csproj" />

    <!-- Resilience: Polly-based retry, circuit breaker, timeout -->
    <ProjectReference Include="..\..\..\Core\src\Pervaxis.Core.Resilience\Pervaxis.Core.Resilience.csproj" />
  </ItemGroup>

</Project>
