# -------------------------------------------------------------------------
# EditorConfig for Pervaxis Genesis
# https://editorconfig.org
# -------------------------------------------------------------------------

root = true

# All files
[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

# Code files
[*.{cs,csx,vb,vbx}]
indent_style = space
indent_size = 4
end_of_line = crlf

# XML project files
[*.{csproj,vbproj,vcxproj,vcxproj.filters,proj,projitems,shproj}]
indent_size = 2

# XML config files
[*.{props,targets,ruleset,config,nuspec,resx,vsixmanifest,vsct}]
indent_size = 2

# JSON files
[*.json]
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_size = 2

# Shell scripts
[*.sh]
end_of_line = lf

# -------------------------------------------------------------------------
# .NET Code Style Rules
# -------------------------------------------------------------------------

[*.cs]
# Code quality rules - suppress some for library code
dotnet_diagnostic.CA1000.severity = none      # Static members on generic types (Result<T> pattern)
dotnet_diagnostic.CA1032.severity = none      # Standard exception constructors
dotnet_diagnostic.CA1056.severity = suggestion # URI vs string properties
dotnet_diagnostic.CA1716.severity = suggestion # Reserved keywords in parameters
dotnet_diagnostic.CA1308.severity = none      # ToLowerInvariant for case-insensitive comparison is acceptable
dotnet_diagnostic.CA1822.severity = suggestion # Mark members as static
dotnet_diagnostic.CA1848.severity = suggestion # Use LoggerMessage delegates
dotnet_diagnostic.CA1859.severity = suggestion # Concrete types for improved performance
dotnet_diagnostic.CA1873.severity = suggestion # Avoid expensive logging params
dotnet_diagnostic.CA2007.severity = none      # ConfigureAwait in library code (not needed in .NET Core+)

# Naming conventions
dotnet_naming_rule.interfaces_should_be_pascal_case_prefixed_with_i.severity = warning
dotnet_naming_rule.interfaces_should_be_pascal_case_prefixed_with_i.symbols = interface
dotnet_naming_rule.interfaces_should_be_pascal_case_prefixed_with_i.style = begins_with_i

dotnet_naming_rule.types_should_be_pascal_case.severity = warning
dotnet_naming_rule.types_should_be_pascal_case.symbols = types
dotnet_naming_rule.types_should_be_pascal_case.style = pascal_case

# Code style
csharp_prefer_braces = true:warning
csharp_style_namespace_declarations = file_scoped:warning
csharp_using_directive_placement = outside_namespace:warning
